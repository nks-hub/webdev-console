{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve"
  },
  "include": ["electron/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist", "dist-electron"]
}
