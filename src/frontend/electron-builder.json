{
  "appId": "com.nks-hub.webdev-console",
  "productName": "NKS WebDev Console",
  "directories": { "output": "release" },
  "files": ["out/**", "package.json"],
  "extraMetadata": {
    "main": "out/main/main.js"
  },
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "publish": [
    {
      "provider": "github",
      "owner": "nks-hub",
      "repo": "webdev-console",
      "releaseType": "release"
    }
  ],
  "win": {
    "target": ["nsis", "portable"],
    "publisherName": "NKS Hub"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false
  },
  "mac": { "target": ["dmg", "zip"] },
  "linux": { "target": ["AppImage"] }
}
